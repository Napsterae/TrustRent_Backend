{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TrustRentDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "COLOCA_A_TUA_CHAVE_AQUI_NO_FICHEIRO_DEVELOPMENT"
  },
  "Gemini": {
    "ApiKey": "COLOCA_A_TUA_API_KEY_GEMINI_AQUI",
    "Model": "gemini-2.0-flash"
  },
  "CloudinarySettings": {
    "CloudName": "NOME_AQUI",
    "ApiKey": "API_KEY_AQUI",
    "ApiSecret": "API_SECRET_AQUI"
  },
  "Storage": {
    "ContractPath": "./storage/leases",
    "RetentionYears": 10
  },
  "Stripe": {
    "SecretKey": "sk_test_COLOCA_AQUI",
    "PublishableKey": "pk_test_COLOCA_AQUI",
    "WebhookSecret": "whsec_COLOCA_AQUI",
    "PlatformFeePerMonth": 3000
  },
  "DigitalSignature": {
    "CMD": {
      "MockEnabled": true,
      "ApiUrl": "https://cmd.autenticacao.gov.pt/",
      "ApplicationId": "YOUR_APP_ID"
    }
  },
  "RequestBodySize": {
    "Rules": [
      { "PathSegment": "/api/properties", "Limit": 104857600 },
      { "PathSegment": "/upload-signed-contract", "Limit": 104857600 },
      { "PathSegment": "/income-validation", "Limit": 104857600 },
      { "PathSegment": "/tax-registration", "Limit": 104857600 },
      { "PathSegment": "/verify-documents", "Limit": 104857600 },
      { "PathSegment": "/attachments", "Limit": 104857600 },
      { "PathSegment": "/avatar", "Limit": 104857600 }
    ]
  }
}